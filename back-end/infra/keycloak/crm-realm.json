{
  "realm": "crm",
  "enabled": true,
  "registrationAllowed": false,
  "clients": [
    {
      "clientId": "crm-gateway",
      "name": "CRM API Gateway",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "crm-gateway-secret",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"]
    },
    {
      "clientId": "crm-frontend",
      "name": "CRM Front-end",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:4200/*", "http://localhost:3000/*"],
      "webOrigins": ["+"]
    }
  ],
  "roles": {
    "realm": [
      { "name": "admin", "description": "Sistem yoneticisi" },
      { "name": "user", "description": "Standart kullanici" }
    ]
  },
  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "email": "testuser@example.com",
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        { "type": "password", "value": "test123", "temporary": false }
      ],
      "realmRoles": ["user"]
    },
    {
      "username": "testadmin",
      "enabled": true,
      "email": "testadmin@example.com",
      "firstName": "Test",
      "lastName": "Admin",
      "credentials": [
        { "type": "password", "value": "admin123", "temporary": false }
      ],
      "realmRoles": ["admin", "user"]
    }
  ]
}
