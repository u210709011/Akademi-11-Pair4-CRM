{
  "realm": "crm",
  "enabled": true,
  "registrationAllowed": false,
  "accessTokenLifespan": 28800,
  "bruteForceProtected": true,
  "failureFactor": 5,
  "waitIncrementSeconds": 900,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 900,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "permanentLockout": false,
  "clients": [
    {
      "clientId": "crm-client",
      "name": "CRM Client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "crm-client-secret",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"]
    },
    {
      "clientId": "crm-client-short-lived",
      "name": "CRM Client (30s JWT - test)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "crm-client-short-lived-secret",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "attributes": {
        "access.token.lifespan": "30"
      }
    }
  ],
  "roles": {
    "realm": [
      { "name": "CRM_AGENT", "description": "CRM Agent Role" }
    ]
  },
  "users": [
    {
      "username": "salesperson",
      "enabled": true,
      "email": "salesperson@example.com",
      "firstName": "Sales",
      "lastName": "Person",
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ],
      "realmRoles": ["CRM_AGENT"]
    },
    {
      "username": "short-lived-test",
      "enabled": true,
      "email": "short-lived-test@example.com",
      "firstName": "Short",
      "lastName": "Lived",
      "credentials": [
        { "type": "password", "value": "password", "temporary": false }
      ],
      "realmRoles": ["CRM_AGENT"]
    }
  ]
}
